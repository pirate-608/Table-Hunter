{
  "manifest_version": 3,
  "name": "Table Hunter",
  "version": "1.0.0",
  "description": "一键提取网页表格，支持CSV/JSON/Markdown/HTML/Excel格式",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": "assets/icon.png"
  },
  "icons": {
    "128": "assets/icon.png"
  }
}